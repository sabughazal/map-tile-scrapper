HOST=0.0.0.0
PORT=8100

REVERSE_PROXY_HOST=127.0.0.1
REVERSE_PROXY_PORT=80

OUTPUT_DIR=./data
SOURCE_URL=https://mt1.google.com/vt/lyrs=s&x={x}&y={y}&z={z}

LOG_FORMAT="%(asctime)s - %(name)s - %(levelname)s - %(message)s"
LOG_LEVEL=INFO

# GeoTIFF Export settings (leave empty or comment out for auto-detection based on CPU count)
# Valid range: 2-8 (or any positive integer if you know what you're doing)
# GEOTIFF_MAX_WORKERS=4
